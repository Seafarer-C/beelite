{
  "name": "@beelite/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite src/renderer --host 127.0.0.1",
    "build": "vue-tsc -p tsconfig.json --noEmit && electron-vite build",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@beelite/graph-engine": "workspace:*",
    "@beelite/ingestion-engine": "workspace:*",
    "@beelite/llm-engine": "workspace:*",
    "@beelite/research-engine": "workspace:*",
    "@beelite/shared": "workspace:*",
    "@beelite/space-engine": "workspace:*",
    "@beelite/storage-engine": "workspace:*",
    "@beelite/whiteboard-engine": "workspace:*",
    "@mixmark-io/domino": "^2.2.0",
    "@vueuse/core": "^14.1.0",
    "jsondiffpatch": "^0.7.3",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-vite": "^5.0.0",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.8"
  }
}
